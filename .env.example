# Environment variables for local development.
# Copy this file to `.env` and fill in the ones you need.
#
# Good news: you can run `npm run dev` with NO `.env` file at all — the map
# loads from the committed fixture under `fixtures/` and the other pages
# render. You only need these variables when you're touching backend code
# or trying to exercise the real API locally.

# ─── Database ──────────────────────────────────────────────────────────────
# Postgres connection string for AWS RDS.
# Required by: scripts in `scripts/` (migrate, seed, backup, export-map-data)
# and `api/*.js` when invoked by a local dev API layer.
# Without it: fixture-mode dev still works; backend scripts and live API do not.
DATABASE_URL=postgresql://user:password@mapping-ai-db.c9sccou2k3xe.eu-west-2.rds.amazonaws.com:5432/mappingai

# ─── Admin key ─────────────────────────────────────────────────────────────
# Authenticates requests to `api/admin.js` (approve/reject/merge/edit/delete).
# Required by: the admin dashboard at `/admin` once you're working against a
# real API; not needed for fixture-mode dev.
ADMIN_KEY=

# ─── Anthropic API keys ────────────────────────────────────────────────────
# Claude Haiku for quality review on submissions (api/submit.js LLM review path).
# Optional — without it, submissions are stored with `llm_review = null`.
ANTHROPIC_API_KEY=

# Separate key for semantic search (api/semantic-search.js) — higher quota,
# rate-limited separately. Optional; without it the semantic search endpoint
# returns 503 (the built-in fallback search still works).
ANTHROPIC_SEMANTIC_SEARCH_KEY=

# ─── Exa (data enrichment) ─────────────────────────────────────────────────
# Web search API used by `scripts/enrich-*.js` to discover people / orgs / PACs.
# Needed only if you're running the enrichment pipeline. Safe to leave blank
# for normal feature development.
EXA_API_KEY=

# ─── AWS credentials ───────────────────────────────────────────────────────
# Needed only for `sam build && sam deploy` and for `scripts/backup-db.js`
# (which writes backups to S3). Use `aws configure` to store these rather
# than putting them here whenever possible.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-2
