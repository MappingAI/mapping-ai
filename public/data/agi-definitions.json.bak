nt-systems","label":"Superintelligent Systems","description":"AGI defined as AI surpassing human intelligence, often linked to recursive self-improvement.","count":55,"cx":0.43144443929977705,"cy":5.267688927317883},{"id":"general-purpose-agents","label":"General-Purpose Agents","description":"AGI defined as flexible, adaptable AI systems that can handle diverse tasks in open-ended environments.","count":45,"cx":0.37467526023217235,"cy":5.821662112995619},{"id":"transformative-societal-impact","label":"Transformative Impact","description":"AGI defined by its potential to fundamentally reshape society, economy, or power structures.","count":27,"cx":-0.6623959553308345,"cy":7.0598856293399095},{"id":"conceptual-critique","label":"Conceptual Critique","description":"Definitions that question, reframe, or reject the standard AGI framing.","count":77,"cx":-0.40893842570605027,"cy":7.0732899343215605},{"id":"augmentative-tools","label":"Augmentative Tools","description":"AGI defined as AI that enhances human capabilities rather than replacing them.","count":15,"cx":-0.5200661776417443,"cy":4.465175993200735}]}